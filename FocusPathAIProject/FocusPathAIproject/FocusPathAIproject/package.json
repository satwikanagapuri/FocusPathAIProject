{
  "name": "focuspath-ai",
  "version": "1.0.0",
  "description": "Full-stack FocusPath AI: Study & Career Assistant (React + Node/Prisma/OpenAI)",
  "main": "backend/index.js",
  "keywords": ["ai", "productivity", "study", "career"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -n FRONTEND,BACKEND -c cyan,magenta \"npm --prefix frontend run dev\" \"npm --prefix backend run dev\"",
    "build": "npm --prefix frontend run build || true",
    "start": "node backend/src/index.js",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
