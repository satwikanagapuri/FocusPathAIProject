generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum AiLogType {
  chat
  study_plan
  career_guidance
  motivation
  resume_optimization
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash    String
  displayName     String?
  oauthProvider   String?
  oauthSubjectId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // User preferences / goals stored as JSON for flexibility.
  preferences Json?

  tasks        Task[]
  studyPlans   StudyPlan[]
  analytics    Analytics[]
  aiLogs       AI_Logs[]

  @@map("Users")
}

model Task {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  subject     String? // optional: used for weak/strong subject analytics
  priority    TaskPriority @default(medium)
  status      TaskStatus   @default(todo)

  deadline    DateTime?
  orderIndex  Int          @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, deadline])

  @@map("Tasks")
}

model StudyPlan {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  // AI generated plan (sessions, checkpoints, suggested topics, etc.)
  planJson    Json
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])

  @@map("StudyPlans")
}

model Analytics {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Store one row per day (at midnight UTC recommended)
  date DateTime

  points                  Int    @default(0)
  streakCount             Int    @default(0)
  pomodoroSessions       Int    @default(0)
  tasksCompleted          Int    @default(0)

  // Weak/strong subject insights computed from tasks/activity
  weakSubjects Json?
  strongSubjects Json?

  achievements Json? // achievements unlocked so far

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date], name: "userId_date")

  @@map("Analytics")
}

model AI_Logs {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      AiLogType
  prompt    String
  response  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])

  @@map("AI_Logs")
}

